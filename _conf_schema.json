{
  "providers": {
    "description": "API 提供商池 (配置你的多个绘画API节点)",
    "type": "template_list",
    "templates": {
      "openai_node": {
        "name": "添加标准 OpenAI 兼容节点",
        "items": {
          "id": {
            "description": "提供商唯一ID (例如: main_node, backup_node)",
            "type": "string",
            "default": "main_node"
          },
          "api_type": {
            "description": "接口类型 (选择 openai_image 为标准画图，openai_chat 为对话伪装出图)",
            "type": "string",
            "options": [
              "openai_image",
              "openai_chat"
            ],
            "default": "openai_image"
          },
          "base_url": {
            "description": "接口地址 (如: https://api.openai.com/v1)",
            "type": "string",
            "default": "https://api.openai.com/v1"
          },
          "api_keys": {
            "description": "API 密钥轮询池 (支持输入多个Key，按回车换行，每次请求自动轮换)",
            "type": "text",
            "default": "sk-xxxxxx"
          },
          "model": {
            "description": "模型名称 (如: dall-e-3, gpt-4o)",
            "type": "string",
            "default": "dall-e-3"
          }
        }
      }
    },
    "default": []
  },
  "chain_text2img": {
    "description": "文生图兜底链路 (按顺序尝试节点ID，用英文逗号分隔)",
    "type": "string",
    "default": "main_node"
  },
  "chain_selfie": {
    "description": "自拍模式兜底链路 (按顺序尝试节点ID，用英文逗号分隔)",
    "type": "string",
    "default": "main_node"
  },
  "personas": {
    "description": "预设人设/画风库",
    "type": "template_list",
    "templates": {
      "anime_style": {
        "name": "二次元画风模板",
        "items": {
          "name": {
            "description": "人设名称",
            "type": "string",
            "default": "二次元"
          },
          "base_prompt": {
            "description": "核心基础提示词",
            "type": "text",
            "default": "masterpiece, best quality, highly detailed, anime style"
          },
          "ref_image_url": {
            "description": "固定参考图URL (可选)",
            "type": "string",
            "default": ""
          }
        }
      },
      "realistic_style": {
        "name": "写实摄影模板",
        "items": {
          "name": {
            "description": "人设名称",
            "type": "string",
            "default": "写实摄影"
          },
          "base_prompt": {
            "description": "核心基础提示词",
            "type": "text",
            "default": "raw photo, 8k uhd, dslr, soft lighting, high quality, film grain"
          },
          "ref_image_url": {
            "description": "固定参考图URL (可选)",
            "type": "string",
            "default": ""
          }
        }
      }
    },
    "default": []
  }
}
