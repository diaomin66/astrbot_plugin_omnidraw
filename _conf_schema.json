{
  "allowed_users": {
    "type": "string",
    "title": "### 🛡️ 权限白名单\n生图权限白名单 (QQ号)",
    "description": "---\n填入允许使用的QQ号，多个用英文逗号隔开。留空则默认全员可用。",
    "default": ""
  },
  "persona_name": { 
    "title": "### 🎭 人设定制\n助理名称", 
    "description": "---\nAI助理的人设称呼，如: 默认助理", 
    "type": "string", 
    "default": "默认助理" 
  },
  "persona_base_prompt": { "title": "外貌特征", "description": "固定在提示词前方的英文正向特征", "type": "text", "default": "masterpiece, best quality, 1girl" },
  "persona_ref_image": { "title": "形象参考图", "description": "直接点击上传人脸/形象参考图", "type": "file", "default": "" },
  
  "enable_optimizer": {
    "type": "bool",
    "title": "### 🧠 提示词副脑 (Prompt Optimizer)\n副脑总开关",
    "description": "---\n开启后，大模型自拍时会调用副脑扩写提示词。关闭则直接使用原词，无延迟。",
    "default": true
  },
  "chain_optimizer": { "title": "执行链路", "description": "调用哪个节点来扩写提示词 (需开启总开关)", "type": "string", "default": "node_1" },
  "optimizer_model": { "title": "指定模型", "description": "推荐极速模型，如 gemini-1.5-flash-preview", "type": "string", "default": "gpt-4o-mini" },
  "optimizer_timeout": { "title": "超时时间 (秒)", "description": "防止副脑卡死主流程，建议 8~15 秒", "type": "string", "default": "15" },
  
  "chain_text2img": { 
    "title": "### 🔗 路由调度\n常规画图链路", 
    "description": "---\n执行 /画 绑定的节点ID", 
    "type": "string", 
    "default": "node_1" 
  },
  "chain_selfie": { "title": "自拍专用链路", "description": "执行 /自拍 绑定的节点ID", "type": "string", "default": "node_1" },
  "chain_video": { "title": "视频生成链路", "description": "执行 /视频 绑定的视频节点ID", "type": "string", "default": "video_node_1" },
  
  "providers": {
    "title": "### 🎨 API 核心节点\n生图节点配置",
    "description": "---\n支持添加多个 OpenAI 兼容协议的生图节点",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "id": { "description": "节点ID", "type": "string", "default": "node_1" },
        "api_type": { "description": "接口模式", "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
        "base_url": { "description": "接口地址", "type": "string", "default": "https://api.openai.com/v1" },
        "api_keys": { "description": "密钥池 (一行一个)", "type": "text", "default": "" },
        "model": { "description": "模型名称", "type": "string", "default": "banana" },
        "timeout": { "description": "超时时间 (秒)", "type": "string", "default": "60" }
      }
    },
    "templates": {
      "openai_node": {
        "name": "➕ 添加生图节点",
        "items": {
          "id": { "description": "节点ID", "type": "string", "default": "node_1" },
          "api_type": { "description": "接口模式", "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
          "base_url": { "description": "接口地址", "type": "string", "default": "https://api.openai.com/v1" },
          "api_keys": { "description": "密钥池", "type": "text", "default": "sk-xxxxxx" },
          "model": { "description": "模型名称", "type": "string", "default": "banana" },
          "timeout": { "description": "超时时间", "type": "string", "default": "60" }
        }
      }
    },
    "default": []
  },
  "video_providers": {
    "title": "视频节点配置",
    "description": "支持长耗时异步视频渲染节点",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "id": { "description": "节点ID", "type": "string", "default": "video_node_1" },
        "api_type": { "description": "接口模式", "type": "string", "options": ["openai_video"], "default": "openai_video" },
        "base_url": { "description": "接口地址", "type": "string", "default": "https://api.example.com" },
        "api_keys": { "description": "密钥池 (一行一个)", "type": "text", "default": "" },
        "model": { "description": "视频模型名称", "type": "string", "default": "sora" },
        "timeout": { "description": "长连接超时 (秒)", "type": "string", "default": "300" }
      }
    },
    "templates": {
      "openai_video_node": {
        "name": "➕ 添加视频节点",
        "items": {
          "id": { "description": "节点ID", "type": "string", "default": "video_node_1" },
          "api_type": { "description": "接口模式", "type": "string", "options": ["openai_video"], "default": "openai_video" },
          "base_url": { "description": "接口地址", "type": "string", "default": "https://api.example.com" },
          "api_keys": { "description": "密钥池", "type": "text", "default": "sk-xxxxxx" },
          "model": { "description": "视频模型名称", "type": "string", "default": "sora" },
          "timeout": { "description": "长连接超时时间", "type": "string", "default": "300" }
        }
      }
    },
    "default": []
  }
}
