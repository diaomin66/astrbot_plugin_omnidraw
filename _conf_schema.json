{
  "allowed_users": {
    "type": "string",
    "title": "🛡️ 权限控制 | 生图白名单 (QQ号)",
    "description": "填入允许使用的QQ号，多个用英文逗号隔开。留空则默认全员可用。",
    "default": ""
  },
  "persona_name": { "title": "🎭 人设定制 | 助理名称", "description": "AI助理的人设称呼，如: 默认助理", "type": "string", "default": "默认助理" },
  "persona_base_prompt": { "title": "🎭 人设定制 | 外貌特征", "description": "固定在提示词前方的英文正向特征", "type": "text", "default": "masterpiece, best quality, 1girl" },
  "persona_ref_image": { "title": "🎭 人设定制 | 形象参考图", "description": "直接点击上传人脸/形象参考图", "type": "file", "default": "" },
  "enable_optimizer": {
    "type": "boolean",
    "title": "🧠 提示词副脑 | 总开关",
    "description": "开启后，大模型自拍时会调用副脑扩写提示词。关闭则直接使用原词，无延迟。",
    "default": true
  },
  "chain_optimizer": { "title": "🧠 提示词副脑 | 执行链路", "description": "调用哪个节点来扩写提示词 (需开启总开关)", "type": "string", "default": "node_1" },
  "optimizer_model": { "title": "🧠 提示词副脑 | 指定模型", "description": "推荐极速模型，如 gpt-4o-mini", "type": "string", "default": "gpt-4o-mini" },
  "optimizer_timeout": { "title": "🧠 提示词副脑 | 超时时间 (秒)", "description": "防止网络拥堵卡死主流程，建议 8~15", "type": "string", "default": "15" },
  "chain_text2img": { "title": "🔗 路由调度 | 常规画图链路", "description": "执行 /画 绑定的节点ID", "type": "string", "default": "node_1" },
  "chain_selfie": { "title": "🔗 路由调度 | 自拍专用链路", "description": "执行 /自拍 绑定的节点ID", "type": "string", "default": "node_1" },
  "chain_video": { "title": "🔗 路由调度 | 视频生成链路", "description": "执行 /视频 绑定的视频节点ID", "type": "string", "default": "video_node_1" },
  "providers": {
    "title": "🎨 核心 | API 生图节点配置",
    "description": "支持添加多个文生图/图生图节点",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "id": { "description": "节点ID", "type": "string", "default": "node_1" },
        "api_type": { "description": "接口模式", "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
        "base_url": { "description": "接口地址", "type": "string", "default": "https://api.openai.com/v1" },
        "api_keys": { "description": "密钥池 (一行一个)", "type": "text", "default": "" },
        "model": { "description": "模型名称 (多个用逗号隔开)", "type": "string", "default": "banana" },
        "timeout": { "description": "超时时间 (秒)", "type": "string", "default": "60" }
      }
    },
    "templates": {
      "openai_node": {
        "name": "➕ 添加生图节点",
        "items": {
          "id": { "description": "节点ID", "type": "string", "default": "node_1" },
          "api_type": { "description": "接口模式", "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
          "base_url": { "description": "接口地址", "type": "string", "default": "https://api.openai.com/v1" },
          "api_keys": { "description": "密钥池", "type": "text", "default": "sk-xxxxxx" },
          "model": { "description": "模型名称", "type": "string", "default": "banana" },
          "timeout": { "description": "超时时间", "type": "string", "default": "60" }
        }
      }
    },
    "default": []
  },
  "video_providers": {
    "title": "🎬 核心 | API 视频节点配置",
    "description": "支持添加挂机渲染长视频节点",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "id": { "description": "节点ID", "type": "string", "default": "video_node_1" },
        "api_type": { "description": "接口模式", "type": "string", "options": ["openai_video"], "default": "openai_video" },
        "base_url": { "description": "接口地址", "type": "string", "default": "https://api.example.com" },
        "api_keys": { "description": "密钥池 (一行一个)", "type": "text", "default": "" },
        "model": { "description": "视频模型名称 (多个用逗号隔开)", "type": "string", "default": "sora" },
        "timeout": { "description": "长连接超时 (秒)", "type": "string", "default": "300" }
      }
    },
    "templates": {
      "openai_video_node": {
        "name": "➕ 添加视频节点",
        "items": {
          "id": { "description": "节点ID", "type": "string", "default": "video_node_1" },
          "api_type": { "description": "接口模式", "type": "string", "options": ["openai_video"], "default": "openai_video" },
          "base_url": { "description": "接口地址", "type": "string", "default": "https://api.example.com" },
          "api_keys": { "description": "密钥池", "type": "text", "default": "sk-xxxxxx" },
          "model": { "description": "视频模型名称", "type": "string", "default": "sora" },
          "timeout": { "description": "长连接超时时间", "type": "string", "default": "300" }
        }
      }
    },
    "default": []
  }
}
