{
  "providers": {
    "description": "API 提供商池",
    "type": "template_list",
    "templates": {
      "openai_node": {
        "name": "添加 OpenAI 兼容节点",
        "items": {
          "id": "main_node",
          "api_type": "openai_image",
          "base_url": "https://api.openai.com/v1",
          "api_keys": "sk-1\nsk-2",
          "model": "dall-e-3"
        }
      }
    },
    "items": {
      "type": "object",
      "keys": {
        "id": {
          "description": "节点ID (用于指令切换和链路配置)",
          "type": "string",
          "default": "main_node"
        },
        "api_type": {
          "description": "接口类型",
          "type": "string",
          "options": ["openai_image", "openai_chat"],
          "default": "openai_image"
        },
        "base_url": {
          "description": "接口地址",
          "type": "string",
          "default": "https://api.openai.com/v1"
        },
        "api_keys": {
          "description": "API 密钥列表 (一行一个，支持轮询)",
          "type": "text",
          "default": ""
        },
        "model": {
          "description": "模型名称 (如 dall-e-3, gpt-4o, flux-1-schnell)",
          "type": "string",
          "default": "dall-e-3"
        }
      }
    },
    "default": []
  },
  "chain_text2img": {
    "description": "文生图链路 (逗号分隔ID)",
    "type": "string",
    "default": "main_node"
  },
  "chain_selfie": {
    "description": "自拍链路",
    "type": "string",
    "default": "main_node"
  },
  "personas": {
    "description": "预设人设库",
    "type": "template_list",
    "templates": {
      "anime": {
        "name": "二次元",
        "items": { "name": "二次元", "base_prompt": "anime style, masterpiece", "ref_image_url": "" }
      }
    },
    "items": {
      "type": "object",
      "keys": {
        "name": { "type": "string" },
        "base_prompt": { "type": "text" },
        "ref_image_url": { "type": "string" }
      }
    }
  }
}
