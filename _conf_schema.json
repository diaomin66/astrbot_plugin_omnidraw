{
  "providers": {
    "description": "API 提供商池 (请确保至少有一个节点支持 Image-to-Image/ControlNet 兼容接口用于自拍)",
    "type": "template_list",
    "templates": {
      "openai_node": {
        "name": "添加标准 OpenAI 兼容节点",
        "items": {
          "id": "main_node",
          "api_type": "openai_image",
          "base_url": "https://api.openai.com/v1",
          "api_keys": "sk-xxxxxx",
          "model": "dall-e-3"
        }
      }
    },
    "items": {
      "type": "object",
      "keys": {
        "id": { "type": "string", "default": "main_node" },
        "api_type": { "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
        "base_url": { "type": "string", "default": "https://api.openai.com/v1" },
        "api_keys": { "type": "text", "default": "" },
        "model": { "type": "string", "default": "dall-e-3" }
      }
    }
  },
  "chain_text2img": { "type": "string", "default": "main_node" },
  "chain_selfie": { "type": "string", "default": "main_node" },
  "personas": {
    "description": "人设库。图片支持使用指令 /设置人设图片 上传，也可在此填入本地绝对路径或URL。",
    "type": "template_list",
    "templates": {
      "default_persona": {
        "name": "我的默认形象",
        "items": {
          "name": "默认人设",
          "base_prompt": "masterpiece, best quality, highly detailed, beautiful girl, long white hair, blue eyes",
          "ref_image_url": ""
        }
      }
    },
    "items": {
      "type": "object",
      "keys": {
        "name": { "description": "人设名称", "type": "string", "default": "默认人设" },
        "base_prompt": { "description": "人设固定描述提示词", "type": "text", "default": "" },
        "ref_image_url": { "description": "参考图路径。若使用本地文件，填入绝对路径。", "type": "string", "default": "" }
      }
    }
  }
}
