{
  "permission_config": {
    "type": "object",
    "description": "🛡️ 权限控制",
    "hint": "管理谁可以使用本插件的生图和视频功能",
    "items": {
      "allowed_users": {
        "type": "string",
        "description": "允许使用的QQ号",
        "hint": "多个用英文逗号隔开。留空则默认全员可用。",
        "default": ""
      }
    },
    "default": {}
  },
  "persona_config": {
    "type": "object",
    "description": "🎭 人设定制",
    "hint": "定义 AI 助理在使用 /自拍 时的专属固定形象",
    "items": {
      "persona_name": { "description": "助理名称", "hint": "如: 默认助理", "type": "string", "default": "默认助理" },
      "persona_base_prompt": { "description": "外貌特征", "hint": "固定在提示词前方的英文正向特征", "type": "text", "default": "masterpiece, best quality, 1girl" },
      "persona_ref_image": { "description": "形象参考图", "hint": "直接点击上传人脸/形象参考图", "type": "file", "default": "" }
    },
    "default": {}
  },
  "optimizer_config": {
    "type": "object",
    "description": "🧠 提示词副脑 (Prompt Optimizer)",
    "hint": "拦截简单指令并自动扩写为高维度英文提示词",
    "items": {
      "enable_optimizer": { "type": "bool", "description": "副脑总开关", "hint": "大模型自拍时是否调用副脑？", "default": true },
      "chain_optimizer": { "description": "执行链路", "hint": "调用哪个节点来扩写提示词", "type": "string", "default": "node_1" },
      "optimizer_model": { "description": "指定模型", "hint": "推荐极速模型，如 gpt-4o-mini", "type": "string", "default": "gpt-4o-mini" },
      "optimizer_timeout": { "description": "超时时间 (秒)", "hint": "建议 8~15 秒", "type": "string", "default": "15" },
      "max_batch_count": { "type": "int", "description": "批量生成数量上限", "hint": "0 表示无上限。防止大模型胡乱调用耗尽余额。", "default": 0 }
    },
    "default": {}
  },
  "router_config": {
    "type": "object",
    "description": "🔗 路由调度",
    "hint": "将不同的指令绑定到具体的 API 节点执行",
    "items": {
      "chain_text2img": { "description": "常规画图链路", "hint": "执行 /画 绑定的节点ID", "type": "string", "default": "node_1" },
      "chain_selfie": { "description": "自拍专用链路", "hint": "执行 /自拍 绑定的节点ID", "type": "string", "default": "node_1" },
      "chain_video": { "description": "视频生成链路", "hint": "执行 /视频 绑定的视频节点ID", "type": "string", "default": "video_node_1" }
    },
    "default": {}
  },
  "presets": {
    "type": "list",
    "description": "✨ 改图预设提示词",
    "hint": "格式：预设名:英文提示词。例如：手办化:Transform into figurine style",
    "default": [
      "手办化:masterpiece, best quality, 3d anime figure, octane render, blind box toy, chibi, tilt-shift, highly detailed, clean background"
    ]
  },
  "providers": {
    "description": "🎨 API 生图节点配置",
    "hint": "支持添加多个 OpenAI 兼容协议的生图节点",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "节点ID": { "type": "string", "default": "node_1" },
        "接口模式": { "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
        "接口地址 (需含/v1)": { "type": "string", "default": "https://api.openai.com/v1" },
        "API密钥": { "type": "text", "default": "" },
        "模型名称": { "type": "string", "default": "banana" },
        "超时时间(秒)": { "type": "string", "default": "60" }
      }
    },
    "templates": {
      "openai_node": {
        "name": "➕ 添加生图节点",
        "items": {
          "节点ID": { "type": "string", "default": "node_1" },
          "接口模式": { "type": "string", "options": ["openai_image", "openai_chat"], "default": "openai_image" },
          "接口地址 (需含/v1)": { "type": "string", "default": "https://api.openai.com/v1" },
          "API密钥": { "type": "text", "default": "sk-xxxxxx" },
          "模型名称": { "type": "string", "default": "banana" },
          "超时时间(秒)": { "type": "string", "default": "60" }
        }
      }
    },
    "default": []
  },
  "video_providers": {
    "description": "🎬 API 视频节点配置",
    "hint": "支持配置各大主流视频模型接口",
    "type": "template_list",
    "items": {
      "type": "object",
      "keys": {
        "节点ID": { "type": "string", "default": "video_node_1" },
        "接口模式": { 
            "type": "string", 
            "options": [
                "async_task (异步排队轮询 - 推荐Kling/Runway/Luma)", 
                "openai_sync (同步阻塞直返 - 适合Sora等官方接口)", 
                "openai_chat (对话伪装视频 - 适合各大中转API)"
            ], 
            "default": "async_task (异步排队轮询 - 推荐Kling/Runway/Luma)"
        },
        "接口地址 (需含/v1)": { "type": "string", "default": "https://api.example.com/v1" },
        "API密钥": { "type": "text", "default": "" },
        "模型名称": { "type": "string", "default": "kling-v1" },
        "超时时间(秒)": { "type": "string", "default": "600" }
      }
    },
    "templates": {
      "video_node": {
        "name": "➕ 添加视频节点",
        "items": {
          "节点ID": { "type": "string", "default": "video_node_1" },
          "接口模式": { 
              "type": "string", 
              "options": [
                  "async_task (异步排队轮询 - 推荐Kling/Runway/Luma)", 
                  "openai_sync (同步阻塞直返 - 适合Sora等官方接口)", 
                  "openai_chat (对话伪装视频 - 适合各大中转API)"
              ], 
              "default": "async_task (异步排队轮询 - 推荐Kling/Runway/Luma)" 
          },
          "接口地址 (需含/v1)": { "type": "string", "default": "https://api.example.com/v1" },
          "API密钥": { "type": "text", "default": "sk-xxxxxx" },
          "模型名称": { "type": "string", "default": "kling-v1" },
          "超时时间(秒)": { "type": "string", "default": "600" }
        }
      }
    },
    "default": []
  }
}
